flowchart TB
    subgraph SYSTEM["TIMEKEEPING SYSTEM"]
        SIS["Internal\nWork Schedule Control"]
    end

    subgraph UPLOAD["1. BATCH UPLOAD"]
        direction TB
        UP["Employee uploads\nall CSVs\nat once"]
        AUTO["System automatically\ndetects report type\nfor each file"]
        UP --> AUTO
    end

    subgraph ENGINE["2. AUTOMATIC PROCESSING"]
        direction TB
        ENC["Automatic encoding\ncorrection\n(UTF-8 / Latin-1)"]
        PARSE["Smart parser\nBR dates, durations\naccented names"]
        NORM["Normalization to\nsingle canonical model\n(5 violation types)"]
        STORE["Storage with\nautomatic deduplication\n(no duplicate data)"]
        ENC --> PARSE --> NORM --> STORE
    end

    subgraph BI["3. INTERACTIVE DASHBOARD"]
        direction TB
        OV["Overview\nAll sectors\nwith color alerts"]
        DET["Monthly Detail\nby violation type\nwith counters"]
        RANK["Employee Ranking\nby total violations\nwith repeat offenders"]
        QUAL["Quality Indicator\nsectors with\nmissing data"]
    end

    subgraph EXPORTAR["4. AUTOMATIC EXPORT"]
        XLSX["Excel Download\nformatted with 1 click"]
    end

    subgraph DECISION["5. DECISION MAKING"]
        direction TB
        THAIS["Manager analyzes\ndashboard in real time"]
        ACAO["Immediate corrective\nactions by sector"]
        THAIS --> ACAO
    end

    SIS --> UP
    AUTO --> ENC
    STORE --> OV
    STORE --> DET
    STORE --> RANK
    STORE --> QUAL
    OV --> THAIS
    DET --> THAIS
    RANK --> THAIS
    QUAL --> THAIS
    THAIS --> XLSX


{
  "name": "smartb-diagrams-vscode",
  "displayName": "SmartB Diagrams",
  "description": "Live AI reasoning diagrams in VS Code",
  "version": "0.1.0",
  "publisher": "smartb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartb/smartb-diagrams"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": ["onWebviewPanel:smartb.diagramPanel"],
  "contributes": {
    "configuration": {
      "title": "SmartB Diagrams",
      "properties": {
        "smartb.serverUrl": {
          "type": "string",
          "default": "ws://localhost:3333/ws",
          "description": "WebSocket URL of the SmartB server"
        },
        "smartb.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to SmartB server on startup"
        }
      }
    },
    "commands": [
      {
        "command": "smartb.reconnect",
        "title": "SmartB: Reconnect to Server"
      },
      {
        "command": "smartb.openBrowser",
        "title": "SmartB: Open in Browser"
      },
      {
        "command": "smartb.showDiagram",
        "title": "SmartB: Show Diagram Panel",
        "icon": "$(preview)"
      }
    ],
    "keybindings": [
      {
        "command": "smartb.showDiagram",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "@vscode/vsce": "^3.2.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}

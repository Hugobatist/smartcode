{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "outDir": "media",
    "rootDir": "src/webview",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true
  },
  "include": ["src/webview/**/*.ts"]
}
